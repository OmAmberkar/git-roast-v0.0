---
import Layout from '../layouts/Layout.astro';
import RoastForm from '../components/RoastForm.jsx';
import './_index.css';
---

<Layout title="GIT_ROAST // PROTOCOL_V1.0">
	<main>
		<div class="system-status">
			<span class="status-box">SYSTEM: ACTIVE</span>
			<span class="status-box">SECURITY: BYPASSED</span>
			<span class="status-box teal">LOAD: CRITICAL</span>
		</div>
		
		<RoastForm client:load />

		<div class="footer-container">
			<div class="scan-line"></div>
			<p class="footer-msg">AUTHORIZATION_LEVEL: DEV_DEVIL // CORE_TEMP: 104°C</p>
		</div>
	</main>
</Layout>

<script>
	import { gsap } from 'gsap';

	window.addEventListener('load', () => {
		// GSAP Initial Animations
		gsap.from('.valo-header', {
			y: 100,
			opacity: 0,
			duration: 1.2,
			ease: "power4.out",
			delay: 0.2
		});

		gsap.from('.status-box', {
			y: -20,
			opacity: 0,
			stagger: 0.1,
			duration: 0.6,
			ease: "back.out(1.7)",
			delay: 0.8
		});

		gsap.from('.sub-header', {
			opacity: 0,
			duration: 1,
			delay: 1
		});
	});
</script>

<style>
	main {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
		position: relative;
		z-index: 10;
	}

	.system-status {
		display: flex;
		gap: 1rem;
		margin-bottom: 2rem;
		font-family: 'Courier New', Courier, monospace;
		font-size: 0.65rem;
		letter-spacing: 2px;
	}

	.status-box {
		padding: 4px 12px;
		border: 1px solid var(--primary);
		color: var(--primary);
		background: rgba(255, 70, 85, 0.05);
		text-transform: uppercase;
	}

	.status-box.teal {
		border-color: var(--cyan);
		color: var(--cyan);
		background: rgba(0, 243, 255, 0.05);
	}

	.header-container {
		text-align: center;
		margin-bottom: 3rem;
	}

	.valo-header {
		font-family: 'Valorant', sans-serif;
		font-size: clamp(3rem, 12vw, 9rem);
		line-height: 0.9;
		margin: 0;
		color: var(--primary);
		text-shadow: 0 0 20px rgba(255, 70, 85, 0.3);
		position: relative;
		letter-spacing: -2px;
	}

	.sub-header {
		font-family: 'Courier New', Courier, monospace;
		letter-spacing: 15px;
		font-size: 0.8rem;
		margin-top: 1rem;
		opacity: 0.6;
		color: var(--cyan);
		text-transform: uppercase;
	}

	.footer-container {
		margin-top: 3rem;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		opacity: 0.5;
	}

	.scan-line {
		width: 100px;
		height: 1px;
		background: var(--primary);
		margin-bottom: 1rem;
		box-shadow: 0 0 10px var(--primary);
	}

	.footer-msg {
		font-family: 'Courier New', Courier, monospace;
		font-size: 0.6rem;
		letter-spacing: 4px;
	}

	@media (max-width: 768px) {
		.valo-header {
			font-size: 3.5rem;
			letter-spacing: 0;
		}
		.sub-header {
			letter-spacing: 5px;
			font-size: 0.6rem;
		}
		main {
			padding: 1rem;
		}
	}
</style>
